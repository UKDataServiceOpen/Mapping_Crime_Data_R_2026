download.file(url, temp_file, mode = "wb")
urban_rural <- read_excel(temp_file) %>%  # or your URL
janitor::clean_names() %>%
select(lsoa21cd, urban_rural_flag, ruc21nm) %>%
rename(rc_cat = ruc21nm) %>%
mutate(urban_rural_flag = recode(urban_rural_flag,
"U" = "Urban",
"R" = "Rural"))
